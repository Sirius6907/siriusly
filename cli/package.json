{
  "name": "siriusly",
  "version": "0.3.1",
  "description": "SiriusEcoSystem CLI — orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "siriusly": "./dist/index.js"
  },
  "keywords": [
    "sirius-eco-system",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sirius-eco-system/sirius-eco-system",
    "directory": "cli"
  },
  "homepage": "https://github.com/sirius-eco-system/sirius-eco-system",
  "bugs": {
    "url": "https://github.com/sirius-eco-system/sirius-eco-system/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && node -e \"import { execSync } from 'node:child_process'; try { if (process.platform !== 'win32') execSync('chmod +x dist/index.js'); } catch (e) {}\"",
    "clean": "node -e \"import fs from 'node:fs'; fs.rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@sirius-eco-system/adapter-claude-local": "workspace:*",
    "@sirius-eco-system/adapter-codex-local": "workspace:*",
    "@sirius-eco-system/adapter-cursor-local": "workspace:*",
    "@sirius-eco-system/adapter-gemini-local": "workspace:*",
    "@sirius-eco-system/adapter-opencode-local": "workspace:*",
    "@sirius-eco-system/adapter-pi-local": "workspace:*",
    "@sirius-eco-system/adapter-openclaw-gateway": "workspace:*",
    "@sirius-eco-system/adapter-aws-openclaw": "workspace:*",
    "@sirius-eco-system/adapter-utils": "workspace:*",
    "@sirius-eco-system/db": "workspace:*",
    "@sirius-eco-system/server": "workspace:*",
    "@sirius-eco-system/shared": "workspace:*",
    "drizzle-orm": "0.38.4",
    "dotenv": "^17.0.1",
    "commander": "^13.1.0",
    "embedded-postgres": "^18.1.0-beta.16",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
