{
  "name": "@sirius-eco-system/plugin-hello-world-example",
  "version": "0.1.0",
  "description": "First-party reference plugin that adds a Hello World dashboard widget",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "siriusEcoSystemPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc",
    "clean": "node -e \"import fs from 'node:fs'; fs.rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "pnpm --filter @sirius-eco-system/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@sirius-eco-system/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
